{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "backend/**",
      "src/**",
      "dist/**",
      "public/**",
      "package.json",
      "package-lock.json",
      "vite.config.js",
      "vite.config.ts",
      "README.md",
      "standalone_app.html",
      "*.md"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
